# Copy to .env.local and fill in from your Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Member provisioning (Zapier → app) ---
# SERVICE ROLE key from Supabase Settings → API. SERVER-ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
# A long random secret you invent. Zapier must send it in the x-provision-secret header.
PROVISION_SECRET=make-this-a-long-random-string

# --- Legacy free-group self-signup (/join page) ---
# A shared access code you post ONLY inside the Skool community. Members enter it
# to create their own account. Rotate it if it leaks.
JOIN_CODE=make-this-a-memorable-code
